<?xml version='1.0' encoding='utf-8'?>
<mujoco model="piper_slope_demo">
  <compiler angle="radian" meshdir="." />
  <option cone="elliptic" impratio="200" integrator="implicitfast"/>
  <statistic center="0.3 0 0.4" extent="1" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
    <global azimuth="120" elevation="-20" />
  </visual>

  <asset>
    <!-- Skybox and ground -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072" />
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300" />
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2" />

    <!-- Demo slope meshes (relative to models/demo/ directory) - scaled to 50% -->
    <mesh file="assets/bottom_fence_left.stl" scale="0.009 0.015 0.01"/>
    <mesh file="assets/bottom_fence_right.stl" scale="0.009 0.015 0.01"/>
    <mesh file="assets/top_fence_left.stl" scale="0.009 0.006 0.01"/>
    <mesh file="assets/top_fence_right.stl" scale="0.009 0.006 0.01"/>
    <mesh file="assets/stopper.stl" scale="0.009 0.015 0.01"/>
    <mesh file="assets/top_slope.stl" scale="0.009 0.006 0.01"/>
    <mesh file="assets/bottom_slope.stl" scale="0.009 0.015 0.01"/>
    <mesh file="assets/stopper_left.stl" scale="0.009 0.015 0.0075"/>
    <mesh file="assets/stopper_right.stl" scale="0.009 0.015 0.0075"/>
    <mesh file="assets/bottom_support_left.stl" scale="0.009 0.015 0.01"/>
    <mesh file="assets/bottom_support_right.stl" scale="0.009 0.015 0.01"/>

    <!--  Piper robot materials -->
    <material name="gray_mat" rgba="0.59 0.59 0.59 1"/>
    <material name="light_gray_mat" rgba="0.98 0.98 0.98 1"/>
    <material name="light_medium_gray_mat" rgba="0.85 0.85 0.85 1"/>
    <material name="dark_gray_mat" rgba="0.086 0.086 0.086 1"/>
    <material name="darker_gray_mat" rgba="0.14 0.14 0.14 1"/>
    <material name="white_mat" rgba="1 1 1 1"/>
    <material name="red_mat" rgba="0.82 0.15 0.15 1"/>
    <material name="black_mat" rgba="0 0 0 1"/>
    <material name="light_blue" rgba="0.79 0.82 0.93 1"/>

    <!-- Piper robot meshes (relative to models/demo/ directory, need ../ to go up to models/) -->
    <mesh file="../agilex_piper/assets/link2_0.obj"/>
    <mesh file="../agilex_piper/assets/link2_1.obj"/>
