  <!-- Include robot body (without assets/compiler which are already defined above) -->
  <include file="../agilex_piper/piper_body.xml" />

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true" />
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" />

    <!-- Demo objects: balls - scaled to 50%, aligned at x=0.30, sorted by y position -->
    <body name="ball1" pos="0.30 -0.05 0.20">
      <freejoint/>
      <geom type="sphere" name="ball1" size="0.0165" condim="3"
        rgba="1 0 0 1" contype="1" conaffinity="1" solref="0.01 1" density="600" friction="1 .03 .003"/>
    </body>
    <body name="ball2" pos="0.30 0.0 0.20">
      <freejoint/>
      <geom type="sphere" name="ball2" size="0.0165" condim="3"
       friction="1 .03 .003" rgba="0 0.6 0 1" contype="1" conaffinity="1" solref="0.01 1" density="600"/>
    </body>
    <body name="ball3" pos="0.30 0.05 0.20">
      <freejoint/>
      <geom type="sphere" name="ball3" size="0.0165" condim="3"
        rgba="1 0.5 0 1" contype="1" conaffinity="1" solref="0.01 1" density="600" friction="1 .03 .003"/>
    </body>
    <body name="ball4" pos="0.30 0.1 0.20">
      <freejoint/>
      <geom type="sphere" name="ball4" size="0.0165" condim="3"
       friction="1 .03 .003" rgba="0.6 0.6 0 1" contype="1" conaffinity="1" solref="0.01 1" density="600"/>
    </body>
    <body name="ball5" pos="0.30 0.15 0.20">
      <freejoint/>
      <geom type="sphere" name="ball5" size="0.0165" condim="3"
        rgba="0.8 0 0.8 1" contype="1" conaffinity="1" solref="0.01 1" density="600" friction="1 .03 .003"/>
    </body>
    <body name="ball6" pos="0.30 0.20 0.20">
      <freejoint/>
      <geom type="sphere" name="ball6" size="0.0165" condim="3"
       friction="1 .03 .003" rgba="0.0 0.2 0.7 1" contype="1" conaffinity="1" solref="0.01 1" density="600"/>
    </body>

    <!-- Slope structure - aligned at x=0.3 with balls -->
    <body name="bottom_fence_left" pos="0.131 0.065 0.0" euler="0 0 3.14159">
      <geom type="mesh" name="bottom_fence_left" mesh="bottom_fence_left" rgba="0 0.369 0.722 1" friction="0 0 0"/>
    </body>
    <body name="bottom_fence_right" pos="0.131 0.065 0.0" euler="0 0 3.14159">
      <geom type="mesh" name="bottom_fence_right" mesh="bottom_fence_right" rgba="0 0.369 0.722 1" friction="0 0 0"/>
    </body>
    <body name="top_fence_left" pos="0.131 0.065 0.0" euler="0 0 3.14159">
      <geom type="mesh" name="top_fence_left" mesh="top_fence_left" rgba="0 0.369 0.722 1" friction="0 0 0"/>
    </body>
    <body name="top_fence_right" pos="0.131 0.065 0.0" euler="0 0 3.14159">
      <geom type="mesh" name="top_fence_right" mesh="top_fence_right" rgba="0 0.369 0.722 1" friction="0 0 0"/>
    </body>
    <body name="stopper" pos="0.131 0.065 0.0" euler="0 0 3.14159">
      <geom type="mesh" name="stopper" mesh="stopper" rgba="0 0.369 0.722 1"/>
    </body>
    <body name="top_slope" pos="0.131 0.065 0.0" euler="0 0 3.14159">
      <geom type="mesh" name="top_slope" mesh="top_slope" rgba="0 0.369 0.722 1"/>
    </body>
    <body name="bottom_slope" pos="0.131 0.065 0.0" euler="0 0 3.14159">
      <geom type="mesh" name="bottom_slope" mesh="bottom_slope" rgba="0 0.369 0.722 1"/>
    </body>
    <body name="stopper_right" pos="0.131 0.065 0.0" euler="0 0 3.14159">
      <geom type="mesh" name="stopper_right" mesh="stopper_right" rgba="0 0.369 0.722 1"/>
    </body>
    <body name="stopper_left" pos="0.131 0.065 0.0" euler="0 0 3.14159">
      <geom type="mesh" name="stopper_left" mesh="stopper_left" rgba="0 0.369 0.722 1"/>
    </body>
    <body name="bottom_support_left" pos="0.131 0.065 0.0" euler="0 0 3.14159">
      <geom type="mesh" name="bottom_support_left" mesh="bottom_support_left" rgba="0 0.369 0.722 1"/>
